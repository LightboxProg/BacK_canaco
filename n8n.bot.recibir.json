        {
            "parameters": {
                "jsCode": "// Extrae el objeto raiz del mensaje entrante\nconst value = $input.item.json;\n\n// Valida la existencia de un mensaje real\nif (!value.messages || value.messages.length === 0) return [];\n\nconst msg = value.messages[0];\nconst contact = value.contacts[0];\n\nlet tipo = msg.type;\nlet contenido = '';\nlet mediaId = null;\nlet mimeType = null;\nlet nombreArchivo = null;\n\n// Asigna el contenido dependiendo si es texto o multimedia\nif (tipo === 'text') {\n  contenido = msg.text.body;\n} else if (['image', 'audio', 'video', 'document', 'sticker', 'voice'].includes(tipo)) {\n  const mediaObj = msg[tipo];\n  mediaId = mediaObj.id;\n  mimeType = mediaObj.mime_type;\n  \n  if (tipo === 'document') {\n    nombreArchivo = mediaObj.filename;\n    contenido = mediaObj.caption || '';\n  } else {\n    contenido = mediaObj.caption || '';\n  }\n}\n\n// Retorna el payload estructurado para el CRM\nreturn {\n  json: {\n    telefono: msg.from,\n    nombre: contact.profile.name,\n    metaMensajeId: msg.id,\n    tipo: tipo,\n    contenido: contenido,\n    mediaId: mediaId,\n    mimeType: mimeType,\n    nombreArchivo: nombreArchivo\n  }\n};\n"
            },
