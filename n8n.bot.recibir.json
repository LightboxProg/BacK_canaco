        {
            "parameters": {
                "jsCode": "const item = $input.item;\n\n// Recupera los datos originales del mensaje que se pierden despues de los nodos de descarga\nconst originalData = $('Code in JavaScript').item.json;\n\n// Restaura todos los campos originales en el JSON actual\nitem.json.telefono = originalData.telefono;\nitem.json.nombre = originalData.nombre;\nitem.json.contenido = originalData.contenido;\nitem.json.tipo = originalData.tipo;\nitem.json.metaMensajeId = originalData.metaMensajeId;\nitem.json.nombreArchivo = originalData.nombreArchivo;\nitem.json.mimeType = originalData.mimeType;\n\n// Verifica si existe algún archivo binario adjunto\nif (item.binary) {\n  const keys = Object.keys(item.binary);\n  \n  if (keys.length > 0) {\n    const fileKey = keys[0];\n    \n    // IMPORTANTE: En n8n con filesystem-v2, item.binary[fileKey].data retorna 'filesystem-v2'\n    // en vez del base64 real. Usamos getBinaryDataBuffer para leer el archivo real del disco.\n    const binaryBuffer = await this.helpers.getBinaryDataBuffer(0, fileKey);\n    item.json.base64Media = binaryBuffer.toString('base64');\n    \n    // Actualiza mimeType con el del archivo descargado si existe\n    if (item.binary[fileKey].mimeType) {\n      item.json.mimeType = item.binary[fileKey].mimeType;\n    }\n    \n    // Si el tipo viene vacío, lo extraemos del mimeType\n    if (!item.json.tipo && item.json.mimeType) {\n        item.json.tipo = item.json.mimeType.split('/')[0]; \n    }\n  } else {\n    item.json.debugError = 'No binary keys found in item.binary';\n  }\n} else {\n  item.json.debugError = 'item.binary is undefined - Download may have failed';\n}\n\nreturn item;"
            },
